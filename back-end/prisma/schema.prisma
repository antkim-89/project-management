generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Rank {
  id         String @id @default(cuid())
  name       String
  baseSalary Int
  users      User[]
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String
  password           String
  mustChangePassword Boolean        @default(true)
  avatarUrl          String?
  rankId             String
  rank               Rank           @relation(fields: [rankId], references: [id])
  teamId             String?
  team               Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  assignments        Assignment[]
  equipments         Equipment[]
  leaveRequests      LeaveRequest[]
  skills             UserSkill[]
  tasks              Task[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Project {
  id             String          @id @default(cuid())
  title          String
  description    String?         @db.Text
  status         String          @default("Active") // Active, At Risk, Completed
  startDate      DateTime
  endDate        DateTime
  budget         Float
  totalManMonths Float?
  price          Float?
  categoryId     String?
  category       ProjectCategory? @relation(fields: [categoryId], references: [id])
  assignments    Assignment[]
  tasks          Task[]
  requiredSkills ProjectSkill[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Assignment {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  projectId              String
  project                Project  @relation(fields: [projectId], references: [id])
  role                   String
  contributionPercentage Int
  startDate              DateTime
  endDate                DateTime
}

model Equipment {
  id           String   @id @default(cuid())
  type         String // Laptop, Monitor, Mobile
  modelName    String
  serialNumber String   @unique
  status       String   @default("Assigned") // Assigned, Maintenance
  health       Int      @default(100)
  purchaseDate DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
}

model EquipmentSetting {
  id          String   @id @default(cuid())
  type        String   @unique
  usefulLife  Int      // 수명 개월수
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  type      String // Annual, Sick, Personal
  status    String   @default("Pending") // Pending, Approved, Rejected
  reason    String?  @db.Text
}

model SkillSet {
  id       String         @id @default(cuid())
  name     String         @unique
  category String // Frontend, Backend, Design
  users    UserSkill[]
  projects ProjectSkill[]
}

model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  skillSetId  String
  skillSet    SkillSet @relation(fields: [skillSetId], references: [id])
  proficiency Int // 1-5
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  dueDate     DateTime
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[]
}

model ProjectSkill {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skillSetId String
  skillSet   SkillSet @relation(fields: [skillSetId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillSetId])
}

model ProjectRole {
  id   String @id @default(cuid())
  name String @unique
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
