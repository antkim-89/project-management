{
  "name": "project-management-root",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "front-end",
    "back-end"
  ],
  "scripts": {
    "front": "pnpm --filter project-management",
    "back": "pnpm --filter project-management-backend",
    "prisma": "pnpm --filter project-management-backend exec prisma",
    "dev": "pnpm -r --parallel dev"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
